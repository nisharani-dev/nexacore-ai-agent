# Ramp / NexaCore — environment template

# Required for live LLM
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

# App
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO
LOG_DIR=./logs
DATA_DIR=./data

# Auth (optional)
AUTH_REQUIRED=false
APP_API_KEY=
RBAC_ENFORCE=false
RBAC_CONFIG_FILE=./config/rbac.yaml

# Integrations: demo (mock) | live (real APIs when creds set)
INTEGRATIONS_MODE=demo
TICKET_BACKEND=jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=ONBOARD
SERVICENOW_INSTANCE_URL=https://yourcompany.service-now.com
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=
SERVICENOW_TABLE=incident
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REMINDER_FROM_EMAIL=onboarding@company.com

# Database — omit for SQLite; set for Postgres
# DATABASE_URL=postgresql://ramp:ramp_dev_password@localhost:5432/ramp

# Memory / Hindsight
HINDSIGHT_BACKEND=local
HINDSIGHT_STORE_PATH=./data/hindsight_store.json
HINDSIGHT_BASE_URL=
HINDSIGHT_API_KEY=
HINDSIGHT_HEALTH_PATH=/health

# Cache
REDIS_URL=redis://localhost:6379/0
MEMORY_CACHE_TTL=120
SESSION_CACHE_TTL=300

# OIDC (optional)
# OIDC_PROVIDER=okta
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# Frontend (Render: set BACKEND_URL to your backend service URL, e.g. https://nexacore-api.onrender.com)
BACKEND_URL=http://backend:8000
