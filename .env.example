# Ramp / NexaCore — environment template

# Required for live LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# App
APP_ENV=development
PORT=8000
LOG_LEVEL=INFO
LOG_DIR=./logs
DATA_DIR=./data

# Auth (optional)
AUTH_REQUIRED=false
APP_API_KEY=

# Integrations: demo (mock) | live (real APIs when creds set)
INTEGRATIONS_MODE=demo
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=ONBOARD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REMINDER_FROM_EMAIL=onboarding@company.com

# Database — omit for SQLite; set for Postgres
# DATABASE_URL=postgresql://ramp:ramp_dev_password@localhost:5432/ramp

# Memory / Hindsight
HINDSIGHT_BACKEND=local
HINDSIGHT_STORE_PATH=./data/hindsight_store.json
HINDSIGHT_BASE_URL=
HINDSIGHT_API_KEY=

# OIDC (optional)
# OIDC_PROVIDER=okta
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
